# Required
OPENAI_API_KEY=sk-...

# Optional overrides
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
MILVUS_HOST=localhost
MILVUS_PORT=19530
SEARCH_MODE=dense
RERANKER_TYPE=cross_encoder
MESH_DB_PATH=data/mesh.duckdb

# Deployment mode: "monolith" (default) or "microservice"
DEPLOY_MODE=monolith
# SEARCH_SERVICE_URL=http://localhost:8001  # only used in microservice mode

# LangFuse (optional — enables tracing dashboard)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
